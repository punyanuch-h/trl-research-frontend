# Playwright E2E Test Configuration
# Copy to .env and fill in values

# Base URL of the application (default: http://localhost:3000)
BASE_URL=http://localhost:3000
#VITE_PUBLIC_API_URL='http://localhost:8080/'

# Researcher credentials (for researcher flow tests)
RESEARCHER_EMAIL=researcher@example.com
RESEARCHER_PASSWORD=Researcher123

# Admin credentials (for admin flow tests)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin123

# Test user for signup (will be created during signup test)
TEST_SIGNUP_EMAIL=test.researcher_%timestamp%@example.com
TEST_SIGNUP_PASSWORD=TestPass123
